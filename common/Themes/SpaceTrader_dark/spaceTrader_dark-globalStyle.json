// This File contains key-value pairs of names and values.

// You should not modify the key names. New keys will be ignored and
// mis-spelled or deleted keys will cause default colors to be used.

// Lines starting with // and line-feed will be ignored.

// the Brand specific file will override the "All" (default) file.
// If a key is not specified in the Brand file, the default value will
// be used.

{
    "colors": {
        //app branding
        "primary":          "#D240C733",
        "primaryDark":      "#8024CE",
        "secondary":        "#01B7FF",
        "tertiary":         "#FF33A3",
        "success":          "#4FC143",
        "warning":          "#FF9900",
        "error":            "#FE2064",
        
		// Adaptives:
		/// [AGoel 03-27-2020]
		/// i.e. A DarkColor for a LightTheme and a LightColor with DarkTheme with various Alpha variations to adapt to the theme.
		/// NOTE: Both the base color as well as alpha values may vary in a random manner.
		/// COMMENT: Used to be darkerGray, darkGray, mediumGray, lightGray, lighterGray respectively.
        "adaptive":           "#FFFFFF1A",    //10% opacity (white)
        "adaptive2":           "#FFFFFF33",    //20% opacity (white)
        "adaptive3":           "#FFFFFF66",    //40% opacity (white)
        "adaptive4":           "#FFFFFFD9",    //85% opacity (white)
        "adaptive5":           "#FFFFFFF2",    //95% opacity (white)
        
        //system
        "white":            "#FFFFFF",
        "black":            "#000000",
        
        //backgrounds
        "viewBackground":           "#0A3977",      // background color
        "contentBackground":        "#224C84",      // contentBackground
        "buttonGroupBackground":    "#0A3977",      // buttonGroupBackground
        "alertModalBackground":     "#186BAF"       // alertModalBackground
    },
    
    "fonts": {
        //weights can be Ultralight, Light, Thin, Regular, Medium, Semibold, Bold, Heavy, Black
        //"SYS" mean default system font (Roboto for Android, San Francisco for iOS)
        // Nasalization Book is Medium for consistency
        
        "mainTitle":            {"family":"Nasalization", "size":21, "weight":"Medium"},
        
        "subTitle":             {"family":"Nasalization", "size":18, "weight":"Medium"},
        "subTitleEmphasis":     {"family":"Nasalization", "size":18, "weight":"Regular"},
        
        "largeTitle":           {"family":"Nasalization", "size":32, "weight":"Medium"},
        
        "smallTitle":           {"family":"Nasalization", "size":16, "weight":"Medium"},
        
        "regularText":          {"family":"Nasalization", "size":14, "weight":"Regular"},
        "regularTextEmphasis":  {"family":"Nasalization", "size":15, "weight":"Bold"},
        
        "mediumText":           {"family":"Nasalization", "size":14, "weight":"Medium"},
        "mediumTextEmphasis":   {"family":"Nasalization", "size":14, "weight":"Regular"},  // currently we are not using it
        
        "smallText":            {"family":"Nasalization", "size":12, "weight":"Medium"},
        "smallTextEmphasis":    {"family":"Nasalization", "size":10, "weight":"bold"},
        
        // textField (labels & error messages)
        "xSmallText":           {"family":"Nasalization", "size":9, "weight":"Medium"},
        
        //SYS-Mono is the default iOS MonospacedDigitFont.
        "largeNumeral":         {"family":"Nasalization", "size":27, "weight":"Medium"},
        "largerNumeral":        {"family":"Nasalization", "size":40, "weight":"Light"}  // currently we are not using it
    },
    
    "dimens": {
        "xSmallMargin":             8.0, //8.0 used to be smallMargin, smallMargin is now 12.0
        "smallMargin":              12.0,
        "mediumMargin":             16.0,
        "largeMargin":              24.0,
        "xLargeMargin":             32.0,
        
        "tileAspectRatio":          0.58,
        "tileCornerRadius":         20.0,
        
        "shadeViewAlpha":           0.35,
        "listItemTallHeight":       70.0,
        
        "shortTransitionAnimationDuration" :  0.2,
        "mediumTransitionAnimationDuration" : 0.35,
        "longTransitionAnimationDuration" :   0.6
    },
    
    "composites": {
        "tileTitle":                {"font":"subTitle", "color":"adaptive5"},
        "pageTitle":                {"font":"mainTitle", "color":"white"},
        "topNavigationButtonTitle": {"font":"smallTitle", "color":"white"}
    }
}
