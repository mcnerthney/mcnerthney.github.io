                    "font": "@Font.mediumText",
                    "color":"@Color.adaptive5"
                }
            }
        },
        "row":{
            "view":{
                "height":64,
                "widthByHeight":8
            },
            "initialsLabel":{
                "content":"transactionDrawerBackground.pdf",
