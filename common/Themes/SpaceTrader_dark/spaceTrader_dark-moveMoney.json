            "typeLabel":{
                "leading":8,
                "composite":{
                    "font":"@Font.regularText",
                    "color":"@Color.aplha5"
                }
            },
            "dateLabel":{
                "leading":8,
                "composite":{
                    "font":{"family":"Nasalization", "size":9, "weight":"Book"},
                    "color":"@Color.aplha5"
                }
            },
            "statusLabel":{
                "leading":8,
                "composite":{
                    "font":"@Font.xSmallText",
                    "color":"@Color.adaptive2"
                }
            },
            "transactorBackgroundImage":{
                "height":48,
                "leading":20,
                "content":"@Color.adaptive2"
            },
            "creditAmountLabel":{
                "trailing":20,
                "composite":{
                    "font":"@Font.regularText",
                    "color":"#C5CED4"
                }
            },
            "pendingAmountLabel":{
                "trailing":20,
                "composite":{
                    "font":"@Font.regularText",
                    "color":"#C5CED4"
                }
            },
            "confirmedAmountLabel":{
                "trailing":20,
                "composite":{
                    "font":"@Font.regularText",
                    "color":"@Color.success"
                }
            }
        }
