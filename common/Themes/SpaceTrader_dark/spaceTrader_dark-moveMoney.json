                    }
                },
                "backgroundImage":{
                    "content":"gridBackground.pdf"
                }
            },
            {
                "view":{
                    "widthByHeight":0.83,
                    "content":""
                },
                "iconImage":{
                    "content":"gridTransfer.pdf"
                },
                "titleLabel":{
                    "content":"TRANSFER",
                    "composite":{
                        "font":"@Font.smallText",
