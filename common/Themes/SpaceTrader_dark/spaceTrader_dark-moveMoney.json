                },
                "backgroundImage":{
                    "content":"gridBackground.pdf"
                }
            }
        ]
    },
    
    "transactors":{
        "view":{
            "bottom":40,
            "width":94,
            "height":110,
            "interItemSpaceX":10
        },
        "informationTitle":{
            "content":"Send or Request Money",
            "composite":{
                "font":"@Font.regularText",
                "color":"@Color.adaptive5"
            }
        },
        "informationDescription":{
            "content":"To Send or Request Money, tap the new button.",
            "composite":{
                "font":"@Font.xSmallText",
                "color":"@Color.adaptive5"
            }
        },
        "icon": {
            "content":"addTransactor.pdf",
            "composite":{
                "font":"@Font.subTitle",
                "color":"@Color.white"
            }
        },
        "background": {
            "width":64,
            "content":"transactorBackground.pdf"
        },
        "description": {
            "height":64,
            "composite":{
                "font":"@Font.smallTextEmphasis",
                "color":"@Color.white"
            }
        },
        "avatar": {
            "width":64
        }
    },
    
    "recentActivity":{
        "view":{
            "top":16,
            "bottom":24,
            "leading":16,
            "trailing":16,
            "content":"@Color.contentBackground"
        },
        "topView":{
            "widthByHeight":8,
            "content":"transactionsTop.pdf"
        },
        "bottomView":{
            "widthByHeight":24,
            "content":"transactionsBottom.pdf"
        },
