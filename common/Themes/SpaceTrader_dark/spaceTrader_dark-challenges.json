{
    "header": {
        "view": {
            "widthByHeight":1.89,
            "content":"challengesHeader.pdf"
        }
    },
    "accountTile": {
        "image": "challengesAccountTile.pdf",
        "nameComposite": {
            "font":"@Font.subTitle",
            "color":"@Color.primaryDark"
        },
        "levelComposite": {
            "font":"@Font.mediumText",
            "color":"@Color.primaryDark"
        },
        "pointsComposite": {
            "font":"@Font.mediumText",
            "color":"@Color.primaryDark"
        },
        "profileImage":{
            "content":"userAvatar.pdf"
        },
        "starImage":{
            "content":"challengesStar.pdf"
        },
        "progressBar": {
            "backgroundColor": "@Color.primary",
            "progressColor": "@Color.success",
            "progressBorderColor": "@Color.primaryDark",
            "borderColor": "@Color.primaryDark",
