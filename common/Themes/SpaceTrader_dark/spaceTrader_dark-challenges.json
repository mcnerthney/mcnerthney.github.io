                "font":"@Font.smallText",
                "color":"@Color.white"
            },
            "rightComposite": {
                "font":"@Font.smallText",
                "color":"@Color.white"
            },
            "centerComposite": {
                "font":"@Font.smallText",
                "color":"@Color.white"
            },
            "trailingComposite": {
                "font":"@Font.smallText",
                "color":"@Color.white"
            }
        }
    },
    "achievementTile": {
        "view": {
            "height": 90
         },
        "badgeItem": {
            "height": 90,
            "width": 90
        }
    },
    "sectionHeader": {
        "titleComposite": {
            "font":"@Font.regularTextEmphasis",
            "color":"@Color.adaptive5"
        },
        "descriptionComposite": {
            "font":"@Font.smallText",
            "color":"@Color.adaptive5"
        }
    },
    "cardTile": {
