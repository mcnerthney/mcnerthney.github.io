            "progressBorderColor": "@Color.primaryDark",
            "borderColor": "@Color.primaryDark",
            "leftComposite": {
                "font":"@Font.smallText",
                "color":"@Color.white"
            },
            "rightComposite": {
                "font":"@Font.smallText",
                "color":"@Color.white"
            },
            "centerComposite": {
                "font":"@Font.smallText",
                "color":"@Color.white"
            },
            "trailingComposite": {
                "font":"@Font.smallText",
                "color":"@Color.white"
            }
        },
        "promotionsBar": {
            "color": "@Color.tertiary",
            "composite": {
                "font":"@Font.smallText",
                "color":"@Color.white"
            }
        }
