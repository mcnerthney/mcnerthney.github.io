// This File contains key-value pairs of names and values.

// You should not modify the key names. New keys will be ignored and
// mis-spelled or deleted keys will cause default colors to be used.

// Lines starting with // and line-feed will be ignored.

// the Brand specific file will override the "All" (default) file.
// If a key is not specified in the Brand file, the default value will
// be used.

{
    "colors": {
        //app branding
        "primary":              "@Color.adaptive2,
        "primaryDark":          "#3F0A9D",
        "secondary":            "#005CFF",
        "tertiary":             "#E81388",
        "success":              "#4FC143",
        "warning":              "#FF9900",
        "error":                "#E40449",
        
		// Adaptives:
		/// [AGoel 03-27-2020]
		/// i.e. A DarkColor for a LightTheme and a LightColor with DarkTheme with various Alpha variations to adapt to the theme.
		/// NOTE: Both the base color as well as alpha values may vary in a random manner.
		/// COMMENT: Used to be darkerGray, darkGray, mediumGray, lightGray, lighterGray respectively.
        "adaptive":               "#0000001A",    //10% opacity (black)
        "adaptive2":               "#00000033",    //20% opacity (black)
        "adaptive3":               "#00000066",    //40% opacity (black)
        "adaptive4":               "#00000099",    //60% opacity (black)
        "adaptive5":               "#000000CC",    //80% opacity (black)
        
        //system
        "white":                "#FFFFFF",
        "black":                "#000000",
        
        //backgrounds
        "viewBackground":           "#F1F4FB",      //background color
        "contentBackground":        "white",        // contentBackground
        "buttonGroupBackground":    "white",        //buttonGroupBackground
        "alertModalBackground":     "#5B06F1"       // alertModalBackground
    },
    
    "fonts": {
        //weights can be Ultralight, Light, Thin, Regular, Medium, Semibold, Bold, Heavy, Black
        //"SYS" mean default system font (Roboto for Android, San Francisco for iOS)
        
        "mainTitle":            {"family":"AvenirNext", "size":44, "weight":"Regular"},
        
        "subTitle":             {"family":"AvenirNext", "size":20, "weight":"Regular"},
        "subTitleEmphasis":     {"family":"AvenirNext", "size":18, "weight":"Demibold"},
        
        "largeTitle":           {"family":"AvenirNext", "size":36, "weight":"Regular"},
        
        "smallTitle":           {"family":"AvenirNext", "size":18, "weight":"Regular"},
        
        "regularText":          {"family":"AvenirNext", "size":16, "weight":"Regular"},
        "regularTextEmphasis":  {"family":"AvenirNext", "size":16, "weight":"Demibold"},
        
        "mediumText":           {"family":"AvenirNext", "size":14, "weight":"Regular"},
        "mediumTextEmphasis":   {"family":"AvenirNext", "size":14, "weight":"Demibold"},
        
        "smallText":            {"family":"AvenirNext", "size":12, "weight":"Regular"},
        "smallTextEmphasis":    {"family":"AvenirNext", "size":12, "weight":"Demibold"},
        
        // textField (labels & error messages)
        "xSmallText":           {"family":"AvenirNext", "size":10, "weight":"Regular"},
        
        //SYS-Mono is the default iOS MonospacedDigitFont.
        "largeNumeral":         {"family":"AvenirNext", "size":32, "weight":"Regular"},
        "largerNumeral":        {"family":"AvenirNext", "size":36, "weight":"Ultralight"}
    },
    
    "dimens": {
        "xSmallMargin":             			8.0,  //8.0 used to be smallMargin, smallMargin is now 12.0
        "smallMargin":              			12.0,
        "mediumMargin":             			16.0,
        "largeMargin":              			24.0,
        "xLargeMargin":             			32.0,
        
        "tileAspectRatio":          			0.58,
        "tileCornerRadius":         			20.0,
        
        "shadeViewAlpha":           			0.35,
        "listItemTallHeight":       			70.0,
        
        "shortTransitionAnimationDuration":     0.2,
        "mediumTransitionAnimationDuration":    0.35,
        "longTransitionAnimationDuration":      0.6
    },
    
    "composites": {
        "tileTitle":                {"font":"subTitle", "color":"adaptive5"},
        "pageTitle":                {"font":"mainTitle", "color":"white"},
        "topNavigationButtonTitle": {"font":"smallTitle", "color":"white"}
    }
}
