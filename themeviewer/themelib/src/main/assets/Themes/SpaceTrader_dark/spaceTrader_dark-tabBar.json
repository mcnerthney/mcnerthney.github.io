///
/// Theme JSON for Tab Bar
///
/// tabs:
///     title                   The title for the tab
///     iconWidthRatio          Ratio of width of icon wrt tab's width
///     iconWidthRatioSelected  Ratio of width of icon wrt tab's width (for a Selected Tab)
///     composite               Font and TextColor for a tab's title
///     compositeSelected       Font and TextColor for a tab's title (for a Selected Tab)
///     icon                    A tab's icon, can be lottie, image
///     iconSelected            A tab's icon, can be lottie, image (for a Selected Tab)
///     background              A tab's background, can be lottie, image, color
///     backgroundSelected      A tab's background, can be lottie, image, color (for a Selected Tab)
///
/// xScaleRatio                 Ratio of Selected tab's width to a normal tab
/// yScaleRatio                 Ratio of Selected tab's height to a normal tab
/// widthByHeightRatio          Ratio of screen's width to tab's height
///
/// background                  Background for the dashboard screens, can be lottie, image, color. Use if common across all dashboards.
/// coverBackground             A continuous cover background, can be lottie, image, color
///
/// ASSUMPTION(s)
///     Tab Icons have 1:1 height to width ratio
///     'background' & 'coverBackground' are only useful when dashboard screens' backgrounds are not opaque
///     App will cater five tabs only, even if the JSON mentions more, the first five will be picked
///
{
    "tabs": [
        {
            "title":"CHALLENGES",
            "iconWidthRatio":0.35,
            "iconWidthRatioSelected":0.5,
            "composite": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            "compositeSelected": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            
            "icon":"tabChallenges.pdf",
            "iconSelected":"tabChallengesSelected.pdf",
            
            "background":"tab.pdf",
            "backgroundSelected":"tabSelected.pdf"
            
        },
        {
            "title":"MOVE MONEY",
            "iconWidthRatio":0.35,
            "iconWidthRatioSelected":0.5,

            "composite": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            "compositeSelected": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            
            "icon":"tabMoveMoney.pdf",
            "iconSelected":"tabMoveMoneySelected.pdf",
            
            "background":"preMiddleTab.pdf",
            "backgroundSelected":"preMiddleTabSelected.pdf"
        },
        {
            "title":"",
            "iconWidthRatio":1,
            "iconWidthRatioSelected":1,
            
            "composite": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            "compositeSelected": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            
            "icon":"tabHome.pdf",
            "iconSelected":"tabHome.pdf",
            
            "background":"middleTab.pdf",
            "backgroundSelected":"middleTabSelected.pdf"
            
        },
        {
            "title":"REWARDS",
            "iconWidthRatio":0.35,
            "iconWidthRatioSelected":0.5,

            "composite": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            "compositeSelected": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            
            "icon":"tabRewards.pdf",
            "iconSelected":"tabRewardsSelected.pdf",
            
            "background":"postMiddleTab.pdf",
            "backgroundSelected":"postMiddleTabSelected.pdf"
            
        },
        {
            "title":"ACCOUNT",
            "iconWidthRatio":0.35,
            "iconWidthRatioSelected":0.5,
            
            "composite": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            "compositeSelected": {
                "font":"@Font.xSmallText",
                "color":"@Color.white"
            },
            
            "icon":"tabAccount.pdf",
            "iconSelected":"tabAccountSelected.pdf",
            
            "background":"tab.pdf",
            "backgroundSelected":"tabSelected.pdf"
            
        }
    ],
    
    "xScaleRatio":1,
    "yScaleRatio":1,
    "widthByHeightRatio":5.45,
    "coverBackground": "@Color.black",
   // "background":  "background.json"           
    "background" : "@Color.viewBackground"
}
