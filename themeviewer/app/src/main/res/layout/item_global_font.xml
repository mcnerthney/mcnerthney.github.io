<?xml version="1.0" encoding="utf-8"?>


<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable
            name="theme"
            type="com.greendotcorp.core.theme.lib.Theme" />
    </data>

<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/global_font_item"
    android:layout_width="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/font_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TextView"
        app:t_textColor='@{theme.globalStyle.color.primary}'
        app:layout_constraintBottom_toTopOf="@id/font_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <TextView
        android:id="@+id/font_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TextView"
        android:layout_marginLeft="10dp"
        app:t_textColor='@{theme.globalStyle.color.primary}'
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/font_name"

        />
</androidx.constraintlayout.widget.ConstraintLayout>
</layout>

